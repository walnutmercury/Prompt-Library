def convert_simple_temp_table_to_cte(sql_query: str) -> tuple[str, list[str]]:
    """
    Convert simple 'SELECT ... INTO #temp FROM ...' into a CTE.

    Returns:
        (converted_sql, warnings)
    """
    import re

    warnings = []

    if not sql_query:
        return sql_query, warnings

    # Find SELECT INTO pattern
    match = re.search(
        r'(select[\s\S]+?)\s+into\s+(#{1,2}\w+)\s+(from[\s\S]+?)(?=\bselect\b|$)',
        sql_query,
        flags=re.IGNORECASE
    )

    if not match:
        return sql_query, warnings

    select_part = match.group(1)
    temp_name = match.group(2).replace("#", "")  # remove # for CTE name
    from_part = match.group(3)

    warnings.append(f"Converted temp table #{temp_name} to CTE")

    # Build CTE
    cte_sql = f";WITH {temp_name} AS (\n{select_part} {from_part}\n)\n"

    # Remove original SELECT INTO block
    sql_query = re.sub(
        r'select[\s\S]+?\s+into\s+#{1,2}\w+\s+from[\s\S]+?(?=\bselect\b|$)',
        '',
        sql_query,
        flags=re.IGNORECASE
    )

    # Replace references to temp table
    sql_query = re.sub(
        r'#{1,2}' + temp_name,
        temp_name,
        sql_query,
        flags=re.IGNORECASE
    )

    return cte_sql + sql_query, warnings



